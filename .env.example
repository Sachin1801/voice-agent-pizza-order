# Copy this file to `.env` for local development and fill in real values.
# Phone numbers should use E.164 format, for example: +14155551234

# Server
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=https://your-public-url.example.com
PUBLIC_WS_BASE_URL=wss://your-public-url.example.com
LOG_LEVEL=info

# Twilio
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567
DEFAULT_TARGET_NUMBER=+15557654321

# Realtime speech + LLM providers
DEEPGRAM_API_KEY=your_deepgram_api_key
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_MODEL_ID=sonic-3
CARTESIA_VOICE_ID=replace_with_cartesia_voice_id

# Artifacts / debugging
ENABLE_AUDIO_RECORDING=false
ARTIFACTS_DIR=./data/runs
